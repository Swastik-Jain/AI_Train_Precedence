# ─────────────────────────────────────────────────────────────
# ORBIT Frontend — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in values for your deployment.
# The .env file is gitignored; this file is safe to commit.

# Base URL of the FastAPI backend (HTTP/S).
# Leave empty (or omit) for local dev — Vite proxies /api → localhost:8000.
# VITE_API_BASE_URL=https://api.myapp.com

# Base URL of the backend WebSocket server.
# Leave empty (or omit) for local dev — Vite proxies /ws → ws://localhost:8000.
# VITE_WS_BASE_URL=wss://api.myapp.com
