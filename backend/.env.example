# ─────────────────────────────────────────────────────────────
# ORBIT Backend — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in values for your deployment.
# The .env file is gitignored; this file is safe to commit.

# ── Database ──────────────────────────────────────────────────
DATABASE_USER=postgres
DATABASE_PASSWORD=password
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=railway_twin

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Defaults to localhost dev origins when not set.
# ALLOWED_ORIGINS=https://myapp.com,https://staging.myapp.com
